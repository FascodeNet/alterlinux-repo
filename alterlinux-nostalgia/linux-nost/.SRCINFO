pkgname = linux-nost
	pkgdesc = The Linux for nostalgic 32-bit machines kernel and modules
	depends = coreutils
	depends = initramfs
	depends = kmod
	optdepends = linux-nost-headers: headers and scripts for building modules
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = scx-scheds: to use sched-ext schedulers
	optdepends = wireless-regdb: to set the correct wireless channels of your country
	provides = KSMBD-MODULE
	provides = NTSYNC-MODULE
	provides = VIRTUALBOX-GUEST-MODULES
	provides = WIREGUARD-MODULE

pkgname = linux-nost-headers
	pkgdesc = Headers and scripts for building modules for the Linux for nostalgic 32-bit machines kernel
	depends = pahole
	provides = LINUX-HEADERS
