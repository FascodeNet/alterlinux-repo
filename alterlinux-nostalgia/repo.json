{
    "name": "alterlinux-nostalgia",
    "maintainer": "hayao <shun819.mail at gmail.com>",
    "build": {
        "repos": [
            {
                "name": "alterlinux-nostalgia",
                "server": "https://alter.repo.hayao0819.com/repo/$repo/$arch"
            }
        ],
        "arches": [
            "pentium4",
            "i686",
            "i486"
        ],
        "image": "ghcr.io/hayao0819/archlinux:$arch",
        "timeout": "5h45m",
        "makepkg": {
            "options": [
                "!debug"
            ],
            "compresszst": "zstd -c -T0 --ultra -20 -"
        }
    },
    "installpkgs": {
        "files": [],
        "names": []
    }
}
