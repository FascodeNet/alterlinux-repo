# Maintainer: hayao <shun819.mail at gmail.com>
# Based on the Arch Linux go package by Morten Linderud <foxboron@archlinux.org>.

# pentium4 uses SSE2 (GO386=sse2); i686/i486 use software float (GO386=softfloat).
# Upstream's 386 runtime needs MMX+CMPXCHG8B for 64-bit atomics (golang/go#37056),
# so the patch swaps in a 486-safe software path under softfloat to reach the i486.

pkgname=go
epoch=2
pkgver=1.26.5
pkgrel=1
pkgdesc='Core compiler tools for the Go programming language'
arch=('i486' 'i686' 'pentium4')
url='https://go.dev/'
license=(BSD-3-Clause)
makedepends=(git)
replaces=(go-pie)
provides=(go-pie)
options=(!strip staticlibs)
source=("https://go.dev/dl/go${pkgver}.src.tar.gz"
        "go-i486-softfloat-atomics.patch"
        "go-bootstrap-${pkgver}-linux-386.tar.gz::https://go.dev/dl/go${pkgver}.linux-386.tar.gz")
noextract=("go-bootstrap-${pkgver}-linux-386.tar.gz")
sha256sums=('495be4bc87176ac567392e5b4116abd98466d33d7b49d41e764ccc6976b2dc42'
            '5a984599a7149d53a8b7334b5fd653a1ea0a3e041b5fbd97fb502ec0ea0f116b'
            '88c162b204e6eefcc32499453b492e80209f4a4c78c33092636901c540fb0d05')

prepare() {
  cd $pkgname
  # It leaves some traces...
  rm -vf src/runtime/{os_plan9.go.orig,os_windows.go.orig,proc.go.orig,vgetrandom_linux.go.orig}

  # 486-safe software 64-bit atomics under GO386=softfloat (no-op for sse2/pentium4).
  patch -Np1 -i "$srcdir/go-i486-softfloat-atomics.patch"
}

build() {
  # Bootstrap from the official prebuilt linux-386 toolchain: archlinux32's go is
  # 1.22.5, too old to build Go 1.26 (needs >=1.24.6). The prebuilt is GO386=sse2 and
  # only runs on the builder (which has SSE2), so it bootstraps every target arch,
  # including the softfloat i486 output.
  mkdir -p "$srcdir/bootstrap"
  tar -C "$srcdir/bootstrap" -xf "$srcdir/go-bootstrap-${pkgver}-linux-386.tar.gz"
  export GOROOT_BOOTSTRAP="$srcdir/bootstrap/go"

  # Force a native 386 build: the builder is x86_64, so make.bash would otherwise
  # treat this as a cross build and nest binaries under bin/linux_386/ (breaking the
  # /usr/bin/go symlink). The 386 bootstrap runs fine on the x86_64 builder.
  export GOHOSTOS=linux GOHOSTARCH=386
  export GOARCH=386
  case "$CARCH" in
    pentium4) export GO386=sse2 ;;      # Pentium 4 has SSE2
    *) export GO386=softfloat ;;        # non-SSE2 i686/i486: software float
  esac
  export GOROOT_FINAL=/usr/lib/go

  # Disable dwarf5 until debugedit catches up
  export GOEXPERIMENT=nodwarf5

  cd "$pkgname/src"
  ./make.bash -v
}

# No check(): the emulated 32-bit build makes the stdlib suite impractically slow.

package() {
  cd "$pkgname"

  install -d "$pkgdir/usr/bin" "$pkgdir/usr/lib/go" "$pkgdir/usr/share/doc/go"

  cp -a bin pkg src lib misc api test "$pkgdir/usr/lib/go"
  # We can't strip all binaries and libraries,
  # as that also strips some testdata directories and breaks the tests.
  # Just strip the packaged binaries as a compromise.
  strip $STRIP_BINARIES "$pkgdir/usr/lib/go"{/bin/*,/pkg/tool/*/*}

  cp -r doc/* "$pkgdir/usr/share/doc/go"

  ln -sf /usr/lib/go/bin/go "$pkgdir/usr/bin/go"
  ln -sf /usr/lib/go/bin/gofmt "$pkgdir/usr/bin/gofmt"
  ln -sf /usr/share/doc/go "$pkgdir/usr/lib/go/doc"

  install -Dm644 VERSION "$pkgdir/usr/lib/go/VERSION"

  rm -rf "$pkgdir/usr/lib/go/pkg/bootstrap"
  rm -rf "$pkgdir"/usr/lib/go/pkg/obj/go-build

  # https://github.com/golang/go/issues/57179
  install -Dm644 go.env "$pkgdir/usr/lib/go/go.env"

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

# vim: ts=2 sw=2 et
